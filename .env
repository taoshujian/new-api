# 本地 go run main.go 使用，与 docker-compose.alone.yml 共用 tsj-mysql / tsj-redis
# 宿主机端口：MySQL 3307、Redis 6380（容器内为 3306 / 6379）

# 数据库（tsj-mysql）
SQL_DSN=root:123456@tcp(127.0.0.1:3307)/new-api
ERROR_LOG_ENABLED=true

# Redis（tsj-redis）
REDIS_CONN_STRING=redis://:123456@127.0.0.1:6380
BATCH_UPDATE_ENABLED=true

# 其他（与 alone 部署一致）
TZ=Asia/Shanghai
NODE_NAME=new-api-local
